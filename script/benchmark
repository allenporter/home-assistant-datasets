#!/usr/bin/env bash
# Convenience wrapper for the benchmark subcommand.
# See: python -m home_assistant_datasets.tool benchmark --help

set -e
cd "$(dirname "$0")/.."

if command -v uv >/dev/null 2>&1; then
  exec uv run python -m home_assistant_datasets.tool benchmark "$@"
else
  exec python -m home_assistant_datasets.tool benchmark "$@"
fi
