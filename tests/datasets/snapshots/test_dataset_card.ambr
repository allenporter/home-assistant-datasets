# serializer version: 1
# name: test_dataset_cards
  list([
    DatasetCard(name='assist', description='A dataset built to exercise the Home Assistant LLM API. The homes for this\ndataset were synthetically generated using gpt-3.5, and then manually curated\nto exercise the Home Assistant intents for controlling devices. The sentences\nwere made intentionally more difficult than the existing assistant NLP for\nshowcasing larger model reasoning capabilities.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://developers.home-assistant.io/blog/2024/05/20/llm-api/'], count=5, version='v2', path='datasets/assist', config_entry_data=None, config_entry_options=None, language=None),
    DatasetCard(name='assist-de', description='Ein Datensatz zum Testen der Home Assistant LLM API. Die Häuser in diesem\nDatensatz wurden synthetisch mit gpt-3.5 generiert und anschließend manuell\nkuratiert, um die Home Assistant Intents zur Gerätesteuerung zu testen. Die\nSätze wurden absichtlich schwieriger gestaltet als die bestehende\nAssistenten-NLP, um die Denkfähigkeiten größerer Modelle zu demonstrieren.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-de', 'https://developers.home-assistant.io/blog/2024/05/20/llm-api/'], count=5, version='v2', path='datasets/assist-de', config_entry_data=None, config_entry_options=None, language='de'),
    DatasetCard(name='assist-es', description='Traduccion al espanol del dataset assist. Un dataset disenado para ejercitar\nla API LLM de Home Assistant. Los hogares de este dataset fueron generados\nsinteticamente usando gpt-3.5, y luego curados manualmente para ejercitar los\nintents de Home Assistant para controlar dispositivos. Las frases fueron\nhechas intencionalmente mas dificiles que el NLP existente del asistente para\ndemostrar las capacidades de razonamiento de modelos mas grandes.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-es', 'https://developers.home-assistant.io/blog/2024/05/20/llm-api/'], count=5, version='v2', path='datasets/assist-es', config_entry_data=None, config_entry_options=None, language='es'),
    DatasetCard(name='assist-fr', description="Traduction française du jeu de données assist. Un jeu de données conçu pour\nexercer l'API LLM de Home Assistant. Les maisons de ce jeu de données ont été\ngénérées de manière synthétique à l'aide de gpt-3.5, puis manuellement\norganisées pour exercer les intents Home Assistant pour le contrôle des\nappareils. Les phrases ont été rendues intentionnellement plus difficiles que\nle NLP assistant existant pour démontrer les capacités de raisonnement des\nmodèles plus grands.", urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-fr', 'https://developers.home-assistant.io/blog/2024/05/20/llm-api/'], count=5, version='v2', path='datasets/assist-fr', config_entry_data=None, config_entry_options=None, language='fr'),
    DatasetCard(name='assist-mini', description='A dataset built to exercise the Home Assistant LLM API. The homes for this\ndataset were synthetically generated using gpt-3.5, and then simplified for\nexercising smaller LLMs.\n\nThis is a variation on the `assist` dataset that tests far fewer entities, devices,\nand areas at once. This is designed given poor performance of local models on the\n`assist` baseline to help with even smaller tasks to focus on to improve quailty.\n\nThe use cases are not intended to be very tricky or complicated and aimed at a\nsmaller context window. The number of devices/entities in each test is intentionally\nsmall (e.g. typically under 5 entities per test) to focus on tool calling capabilities\nrather than context retrieval.\n\nThis dataset uses the `assist` format. See the `assist` dataset card and README for\nadditional details about the format and information about running the evaluation.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-mini'], count=4, version='v1', path='datasets/assist-mini', config_entry_data=None, config_entry_options=None, language=None),
    DatasetCard(name='assist-mini-de', description='A German translation of the assist-mini dataset built to exercise the Home Assistant\nLLM API. The homes for this dataset were synthetically generated using gpt-3.5, and\nthen simplified for exercising smaller LLMs.\n\nThis is a variation on the `assist` dataset that tests far fewer entities, devices,\nand areas at once. This is designed given poor performance of local models on the\n`assist` baseline to help with even smaller tasks to focus on to improve quailty.\n\nThe use cases are not intended to be very tricky or complicated and aimed at a\nsmaller context window. The number of devices/entities in each test is intentionally\nsmall (e.g. typically under 5 entities per test) to focus on tool calling capabilities\nrather than context retrieval.\n\nThis dataset uses the `assist` format. See the `assist` dataset card and README for\nadditional details about the format and information about running the evaluation.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-mini-de'], count=4, version='v1', path='datasets/assist-mini-de', config_entry_data=None, config_entry_options=None, language='de'),
    DatasetCard(name='assist-mini-es', description='Traduccion al espanol del dataset assist-mini. Un dataset disenado para\nejercitar la API LLM de Home Assistant. Los hogares de este dataset fueron\ngenerados sinteticamente usando gpt-3.5, y luego simplificados para\nejercitar LLMs mas pequenos.\n\nEsta es una variacion del dataset `assist` que prueba muchas menos entidades,\ndispositivos y areas a la vez. Esta disenado dado el bajo rendimiento de los\nmodelos locales en la linea base `assist` para ayudar con tareas aun mas\npequenas en las que enfocarse para mejorar la calidad.\n\nLos casos de uso no pretenden ser muy complicados y estan orientados a una\nventana de contexto mas pequena. El numero de dispositivos/entidades en cada\nprueba es intencionalmente pequeno (por ejemplo, normalmente menos de 5\nentidades por prueba) para enfocarse en las capacidades de llamada a\nherramientas en lugar de la recuperacion de contexto.\n\nEste dataset usa el formato `assist`. Consulte la tarjeta del dataset `assist`\ny el README para mas detalles sobre el formato e informacion sobre la\nejecucion de la evaluacion.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-mini-es'], count=4, version='v1', path='datasets/assist-mini-es', config_entry_data=None, config_entry_options=None, language='es'),
    DatasetCard(name='assist-mini-fr', description="Traduction française du jeu de données assist-mini. Un jeu de données conçu\npour exercer l'API LLM de Home Assistant. Les maisons de ce jeu de données\nont été générées de manière synthétique à l'aide de gpt-3.5, puis simplifiées\npour exercer des LLM plus petits.\n\nIl s'agit d'une variante du jeu de données `assist` qui teste beaucoup moins\nd'entités, d'appareils et de zones à la fois. Il est conçu étant donné les\nmauvaises performances des modèles locaux sur la base `assist` pour aider à\ndes tâches encore plus petites afin d'améliorer la qualité.\n\nLes cas d'utilisation ne sont pas destinés à être très complexes ou compliqués\net visent une fenêtre de contexte plus petite. Le nombre d'appareils/entités\ndans chaque test est intentionnellement petit (par exemple, généralement moins\nde 5 entités par test) pour se concentrer sur les capacités d'appel d'outils\nplutôt que sur la récupération de contexte.\n\nCe jeu de données utilise le format `assist`. Voir la carte du jeu de données\n`assist` et le README pour plus de détails sur le format et les informations\nsur l'exécution de l'évaluation.", urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-mini-fr'], count=4, version='v1', path='datasets/assist-mini-fr', config_entry_data=None, config_entry_options=None, language='fr'),
    DatasetCard(name='assist-mini-nl', description='A Dutch translation of the assist-mini dataset built to exercise the Home Assistant\nLLM API. The homes for this dataset were synthetically generated using gpt-3.5, and\nthen simplified for exercising smaller LLMs.\n\nThis is a variation on the `assist` dataset that tests far fewer entities, devices,\nand areas at once. This is designed given poor performance of local models on the\n`assist` baseline to help with even smaller tasks to focus on to improve quailty.\n\nThe use cases are not intended to be very tricky or complicated and aimed at a\nsmaller context window. The number of devices/entities in each test is intentionally\nsmall (e.g. typically under 5 entities per test) to focus on tool calling capabilities\nrather than context retrieval.\n\nThis dataset uses the `assist` format. See the `assist` dataset card and README for\nadditional details about the format and information about running the evaluation.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-mini-nl'], count=4, version='v1', path='datasets/assist-mini-nl', config_entry_data=None, config_entry_options=None, language='nl'),
    DatasetCard(name='assist-nl', description='Nederlandse vertaling van de assist-dataset, gebouwd om de Home Assistant LLM API\nte testen. De woningen in deze dataset zijn synthetisch gegenereerd met gpt-3.5 en\nvervolgens handmatig samengesteld om de Home Assistant intents voor het aansturen\nvan apparaten te testen. De zinnen zijn opzettelijk moeilijker gemaakt dan de\nbestaande assistent-NLP om de redeneercapaciteiten van grotere modellen te\ndemonstreren.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist-nl', 'https://developers.home-assistant.io/blog/2024/05/20/llm-api/'], count=5, version='v2', path='datasets/assist-nl', config_entry_data=None, config_entry_options=None, language='nl'),
    DatasetCard(name='automations', description='A dataset for evaluating automation generation. The homes for this dataset were\nsynthetically generated using gpt-3.5. This dataset is in development and contains\njust a few initial examples. Each benchmark creates a synthetic home fixture\nand configures the entities with a particular state, then asks for an automation\nfor a specific set of devices.\n\nThe benchmark loads a synthetic home and runs pytest with Home Assistant to\nrun through scenarios that should trigger the automation. It also gives points\nfor getting inputs correct and each problem benchmark exercises different\nscenarios that add to the overall score. The various scenarios are not weighted.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations'], count=5, version='v0', path='datasets/automations', config_entry_data=None, config_entry_options={'llm_hass_api': '', 'max_tokens': 4096}, language=None),
    DatasetCard(name='automations-de', description='Ein Datensatz zur Bewertung der Automatisierungsgenerierung. Die Haushalte\nin diesem Datensatz wurden synthetisch mit gpt-3.5 erzeugt. Dieser\nDatensatz befindet sich in der Entwicklung und enthaelt nur wenige erste\nBeispiele. Jeder Test erstellt ein synthetisches Zuhause und konfiguriert\ndie Entitaeten mit einem bestimmten Zustand, und fordert dann eine\nAutomatisierung fuer eine bestimmte Gruppe von Geraeten an.\n\nDer Test laedt ein synthetisches Zuhause und fuehrt pytest mit Home Assistant\naus, um Szenarien durchzuspielen, die die Automatisierung ausloesen sollten.\nAusserdem werden Punkte fuer die richtigen Eingaben vergeben, und jeder Test\nprueft verschiedene Szenarien, die zur Gesamtpunktzahl beitragen. Die\nverschiedenen Szenarien sind nicht gewichtet.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations-de'], count=5, version='v0', path='datasets/automations-de', config_entry_data=None, config_entry_options={'llm_hass_api': '', 'max_tokens': 4096}, language='de'),
    DatasetCard(name='automations-es', description='Un conjunto de datos para evaluar la generacion de automatizaciones. Los hogares\nde este conjunto de datos fueron generados sinteticamente usando gpt-3.5. Este\nconjunto de datos esta en desarrollo y contiene solo unos pocos ejemplos iniciales.\nCada prueba crea un hogar sintetico y configura las entidades con un estado\nparticular, luego solicita una automatizacion para un conjunto especifico de\ndispositivos.\n\nLa prueba carga un hogar sintetico y ejecuta pytest con Home Assistant para\nrecorrer escenarios que deberian activar la automatizacion. Tambien otorga puntos\npor obtener las entradas correctas y cada prueba ejercita diferentes escenarios\nque se suman a la puntuacion general. Los distintos escenarios no estan ponderados.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations-es'], count=5, version='v0', path='datasets/automations-es', config_entry_data=None, config_entry_options={'llm_hass_api': '', 'max_tokens': 4096}, language='es'),
    DatasetCard(name='automations-fr', description="Un jeu de donnees pour evaluer la generation d'automatisations. Les maisons\nde ce jeu de donnees ont ete generees synthetiquement a l'aide de gpt-3.5. Ce\njeu de donnees est en cours de developpement et ne contient que quelques exemples\ninitiaux. Chaque test cree une maison synthetique et configure les entites avec un\netat particulier, puis demande une automatisation pour un ensemble specifique\nd'appareils.\n\nLe test charge une maison synthetique et execute pytest avec Home Assistant pour\nparcourir des scenarios qui devraient declencher l'automatisation. Il attribue\negalement des points pour l'obtention des entrees correctes et chaque test met en\noeuvre differents scenarios qui s'ajoutent au score global. Les differents scenarios\nne sont pas ponderes.", urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations-fr'], count=5, version='v0', path='datasets/automations-fr', config_entry_data=None, config_entry_options={'llm_hass_api': '', 'max_tokens': 4096}, language='fr'),
    DatasetCard(name='automations-nl', description="Een dataset voor het evalueren van het genereren van automatiseringen. De woningen\nin deze dataset zijn synthetisch gegenereerd met gpt-3.5. Deze dataset is in\nontwikkeling en bevat slechts enkele eerste voorbeelden. Elke test maakt een\nsynthetische woning aan en configureert de entiteiten met een bepaalde status,\nen vraagt vervolgens om een automatisering voor een specifieke set apparaten.\n\nDe test laadt een synthetische woning en voert pytest uit met Home Assistant om\nscenario's te doorlopen die de automatisering zouden moeten activeren. Er worden\nook punten gegeven voor het correct instellen van de invoer en elke test oefent\nverschillende scenario's die bijdragen aan de totale score. De verschillende\nscenario's zijn niet gewogen.", urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/automations-nl'], count=5, version='v0', path='datasets/automations-nl', config_entry_data=None, config_entry_options={'llm_hass_api': '', 'max_tokens': 4096}, language='nl'),
    DatasetCard(name='intents', description='A dataset built form the Home Assistant intents repo, modeled after existing\nNLP test cases for the assistant pipeline.\n\nThis dataset has been adapted for evaluating the Home Assistant LLM API ([blog post](https://developers.home-assistant.io/blog/2024/05/20/llm-api/))\nimported from the home assistant intents repo.\n\nThis is mean to reuse the tests that already exist for the NLP, which turns out\nto expose some weaknesses or differences of interpretation of tasks. It also is\na very large home which is challenging for smaller models given the ~100 or so\ndevices. Lastly, there are some tests that have subtle mismatches that are reasonable (e.g.\n"minimum brightness" tests)\n\nThis dataset uses the `assist` format. See the `assist` dataset card and README for\nadditional details about the format and information about running the evaluation.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/intents', 'https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/assist', 'https://github.com/home-assistant/intents'], count=None, version=None, path='datasets/intents', config_entry_data=None, config_entry_options=None, language=None),
    DatasetCard(name='questions', description='A dataset built to exercise question and answering capabilities of the Home\nAssistant LLM API. The homes for this dataset were synthetically generated\nand then manually curated to exercise the Home Assistant\nintents for querying device state.\n\nThis dataset is currently in development and is not yet complete. It may\ncontain bugs or incomplete data. We welcome contributions to improve the\ndataset. Please see repo docs for more information on how to contribute.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/questions'], count=10, version=None, path='datasets/questions', config_entry_data=None, config_entry_options=None, language=None),
    DatasetCard(name='questions-de', description='Ein Datensatz zum Testen der Frage-Antwort-Funktionen der Home Assistant\nLLM-API. Die Häuser in diesem Datensatz wurden synthetisch generiert\nund anschließend manuell kuratiert, um die Home Assistant\nIntents zur Abfrage von Gerätezuständen zu testen.\n\nDieser Datensatz befindet sich derzeit in der Entwicklung und ist noch nicht\nvollständig. Er kann Fehler oder unvollständige Daten enthalten. Wir freuen\nuns über Beiträge zur Verbesserung des Datensatzes. Weitere Informationen\nzur Mitwirkung finden Sie in der Dokumentation des Repositories.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/questions-de'], count=10, version=None, path='datasets/questions-de', config_entry_data=None, config_entry_options=None, language='de'),
    DatasetCard(name='questions-es', description='Un conjunto de datos creado para ejercitar las capacidades de preguntas y\nrespuestas de la API LLM de Home Assistant. Los hogares de este conjunto de\ndatos fueron generados sinteticamente y luego curados manualmente para\nejercitar los intents de Home Assistant para consultar el estado de los\ndispositivos.\n\nEste conjunto de datos esta actualmente en desarrollo y aun no esta completo.\nPuede contener errores o datos incompletos. Agradecemos contribuciones para\nmejorar el conjunto de datos. Consulte la documentacion del repositorio para\nmas informacion sobre como contribuir.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/questions-es'], count=10, version=None, path='datasets/questions-es', config_entry_data=None, config_entry_options=None, language='es'),
    DatasetCard(name='questions-fr', description="Un jeu de donn\\xe9es con\\xe7u pour exercer les capacit\\xe9s de questions-r\\xe9ponses de\nl'API LLM de Home Assistant. Les maisons de ce jeu de donn\\xe9es ont \\xe9t\\xe9 g\\xe9n\\xe9r\\xe9es\nsynth\\xe9tiquement puis manuellement organis\\xe9es pour exercer les intentions\nHome Assistant pour interroger l'\\xe9tat des appareils.\n\nCe jeu de donn\\xe9es est actuellement en d\\xe9veloppement et n'est pas encore complet.\nIl peut contenir des bogues ou des donn\\xe9es incompl\\xe8tes. Les contributions pour\nam\\xe9liorer le jeu de donn\\xe9es sont les bienvenues. Veuillez consulter la\ndocumentation du d\\xe9p\\xf4t pour plus d'informations sur comment contribuer.", urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/questions-fr'], count=10, version=None, path='datasets/questions-fr', config_entry_data=None, config_entry_options=None, language='fr'),
    DatasetCard(name='questions-nl', description='Een dataset gebouwd om de vraag- en antwoordmogelijkheden van de Home\nAssistant LLM API te testen. De woningen voor deze dataset zijn synthetisch\ngegenereerd en vervolgens handmatig samengesteld om de Home Assistant\nintents voor het opvragen van apparaatstatus te testen.\n\nDeze dataset is momenteel in ontwikkeling en is nog niet compleet. Het kan\nfouten of onvolledige gegevens bevatten. We verwelkomen bijdragen om de\ndataset te verbeteren. Zie de repo-documentatie voor meer informatie over\nhoe je kunt bijdragen.', urls=['https://github.com/allenporter/home-assistant-datasets/tree/main/datasets/questions-nl'], count=10, version=None, path='datasets/questions-nl', config_entry_data=None, config_entry_options=None, language='nl'),
  ])
